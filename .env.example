SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ── External APIs (Person 4) ───────────────────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mini-aladdin-bot/1.0

# ── FRED API (Person 2 — Macro Ingestion) ─────────────────────────────────────
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── MCP Server 1 (Person 2 — Numerical Pipeline) ──────────────────────────────
# Run: uvicorn mcp_server_1.main:app --host 0.0.0.0 --port 8100 --reload
MCP1_HOST=0.0.0.0
MCP1_PORT=8100
MCP1_DEBUG=True
MCP1_DJANGO_SETTINGS_MODULE=config.settings

# Connection pool settings
MCP1_HTTP_POOL_MAX_CONNECTIONS=20
MCP1_HTTP_POOL_MAX_KEEPALIVE=10
MCP1_HTTP_TIMEOUT_SECONDS=30.0

# In-memory cache TTL (seconds)
MCP1_CACHE_TTL_PRICE=300
MCP1_CACHE_TTL_FUNDAMENTALS=3600
MCP1_CACHE_TTL_MACRO=3600

# Rate limits (requests per minute per source)
MCP1_RATE_LIMIT_YFINANCE=30
MCP1_RATE_LIMIT_FRED=20
MCP1_RATE_LIMIT_RBI=10
MCP1_RATE_LIMIT_NSE=15
